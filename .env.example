# General
APP_ENV=development
APP_NAME=Dimensions API
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dimensions
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
OVERPASS_URL=https://overpass-api.de/api/interpreter
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup
DEFAULT_CITY_CODE=MUMBAI
DEFAULT_CONTEXT_RADIUS_M=200

# Object storage
S3_ENDPOINT_URL=
S3_REGION=ap-south-1
S3_BUCKET=dimensions-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PRESIGN_TTL_SECONDS=3600
LOCAL_ARTIFACT_DIR=./artifacts

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
VITE_GEOCODER_PROVIDER=nominatim

